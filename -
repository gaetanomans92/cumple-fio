<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ETAMA — Menú Sábado</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

body {
font-family: 'Inter', sans-serif;
background:#f4f1ec;
margin:0;
padding:0;
color:#2e2e2e;
}

.container {
max-width:680px;
margin:auto;
padding:40px 20px;
}

.logo {
text-align:center;
font-size:26px;
letter-spacing:4px;
margin-bottom:6px;
font-weight:500;
}

.subtitle {
text-align:center;
color:#7a7a7a;
margin-bottom:35px;
font-size:14px;
}

.card {
background:white;
border-radius:18px;
padding:20px;
margin-bottom:16px;
border:1px solid #ece7df;
transition:0.25s;
cursor:pointer;
display:flex;
align-items:flex-start;
gap:15px;
}

.card:hover {
border:1px solid #d8d1c5;
transform:translateY(-1px);
}

input[type="radio"] {
margin-top:4px;
transform:scale(1.2);
accent-color:#3a5a40;
}

.card-content {
flex:1;
}

.plato-header {
display:flex;
justify-content:space-between;
align-items:flex-start;
gap:10px;
}

.plato-title {
font-weight:600;
font-size:17px;
}

.price {
font-weight:500;
color:#3a5a40;
white-space:nowrap;
}

.plato-desc {
color:#6f6f6f;
font-size:14px;
margin-top:6px;
line-height:1.4;
}

.form-group {
margin-top:28px;
}

input[type="text"] {
width:100%;
padding:16px;
border-radius:12px;
border:1px solid #e3ded6;
font-size:15px;
background:white;
}

button {
width:100%;
padding:18px;
background:#3a5a40;
color:white;
border:none;
border-radius:14px;
font-size:15px;
margin-top:24px;
cursor:pointer;
transition:0.25s;
font-weight:500;
}

button:hover {
background:#344e41;
}

.limit {
text-align:center;
margin-top:24px;
color:#7a7a7a;
font-size:13px;
}

.footer {
text-align:center;
margin-top:28px;
color:#a0a0a0;
font-size:12px;
}

input[type="radio"]:checked + .card-content {
}

</style>

</head>

<body>

<div class="container">

<div class="logo">ETAMA</div>
<div class="subtitle">Comida rica que te hace bien</div>

<form action="https://docs.google.com/forms/d/e/FORM_ID/formResponse" method="POST" target="_blank">

<label class="card">
<input type="radio" name="entry.111111" value="Bowl de Pollo" required>
<div class="card-content">
<div class="plato-header">
<div class="plato-title">Bowl de Pollo</div>
<div class="price">12,50€</div>
</div>
<div class="plato-desc">Arroz, pollo, aguacate, tomate cherry, tirabeques salteados y cebolla encurtida</div>
</div>
</label>

<label class="card">
<input type="radio" name="entry.111111" value="Bowl del Mar del Norte">
<div class="card-content">
<div class="plato-header">
<div class="plato-title">Bowl del Mar del Norte</div>
<div class="price">13,50€</div>
</div>
<div class="plato-desc">Arroz con salmón ahumado, mango, papaya, aguacate y verduras frescas</div>
</div>
</label>

<label class="card">
<input type="radio" name="entry.111111" value="Curry Thai de Coco">
<div class="card-content">
<div class="plato-header">
<div class="plato-title">Curry Thai de Coco 🌶️</div>
<div class="price">12,50€</div>
</div>
<div class="plato-desc">Arroz, pollo cocinado con curry verde y leche de coco, vegetales y frutos secos</div>
</div>
</label>

<label class="card">
<input type="radio" name="entry.111111" value="Huevos Trufados">
<div class="card-content">
<div class="plato-header">
<div class="plato-title">Huevos Trufados</div>
<div class="price">12,00€</div>
</div>
<div class="plato-desc">Huevos cocinados a baja temperatura sobre holandesa, paté de trufa, aceite de trufa y pan de masa madre</div>
</div>
</label>

<div class="form-group">
<input type="text" name="entry.222222" placeholder="Nombre (Alergias)">
</div>

<button type="submit">Reservar mi plato</button>

</form>

<div class="limit">
Reservas abiertas hasta jueves 21:00
</div>

<div class="footer">
ETAMA · Menú especial sábado
</div>

</div>

</body>
</html>
